# Copy this file to .env and fill in the values

# --- Security (REQUIRED in production) ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=signal-clone-super-secret-key-change-in-production-2024

# --- Database ---
# Local SQLite (default). Leave unset on Render free tier — the app
# auto-seeds demo data on startup. Only set this if you attach a paid
# persistent disk (e.g. DATABASE_URL=sqlite:////data/signal_clone.db).
DATABASE_URL=sqlite:///./signal_clone.db

# --- CORS ---
# Comma-separated list of allowed frontend origins
# Local development:
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production (replace with your Vercel URL):
# ALLOWED_ORIGINS=https://signal-clone-yourname.vercel.app
